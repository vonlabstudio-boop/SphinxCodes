    var className = classNameFromFile(file.name);
    var content = selectedTemplate.content.split('[Name]').join(className);
    cm.setValue(content);
    templateEl.overlay.classList.remove('show');
    updateStatus();
    cm.focus();
  }

  el.btnTemplate.addEventListener('click', openTemplatePicker);
