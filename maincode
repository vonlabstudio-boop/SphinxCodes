  /* ---------- kaydetme ---------- */
  function downloadFile(file){
    var blob = new Blob([file.doc.getValue()], {type:'text/plain;charset=utf-8'});
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url; a.download = file.name;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(function(){ URL.revokeObjectURL(url); }, 500);
    file.dirty = false;
    renderTabs(); updateStatus(); flashSaved();
  }

  function saveCurrent(){
    var file = files.find(function(f){ return f.id === activeId; });
    if (!file) return;
    var content = file.doc.getValue();

    if (file.handle){
      file.handle.createWritable().then(function(w){
        return w.write(content).then(function(){ return w.close(); });
      }).then(function(){
        file.dirty = false; renderTabs(); updateStatus(); flashSaved();
      }).catch(function(){ downloadFile(file); });
      return;
    }

    if (window.showSaveFilePicker){
      window.showSaveFilePicker({suggestedName: file.name}).then(function(handle){
        return handle.createWritable().then(function(w){
          return w.write(content).then(function(){ return w.close(); }).then(function(){ return handle; });
        });
      }).then(function(handle){
        file.handle = handle; file.name = handle.name; file.dirty = false;
        renderTabs(); updateStatus(); flashSaved();
      }).catch(function(){ /* iptal edildi */ });
      return;
    }

    downloadFile(file);
  }

  function downloadCurrent(){
    var file = files.find(function(f){ return f.id === activeId; });
    if (file) downloadFile(file);
  }

  /* ---------- kapatma onayı ---------- */
  var pendingClose = null;
  function askCloseConfirm(file){
    pendingClose = file;
    el.modalOverlay.classList.add('show');
  }
  el.modalCancel.addEventListener('click', function(){ el.modalOverlay.classList.remove('show'); pendingClose = null; });
  el.modalDiscard.addEventListener('click', function(){
    if (pendingClose) closeFile(pendingClose, true);
    el.modalOverlay.classList.remove('show'); pendingClose = null;
  });
  el.modalSave.addEventListener('click', function(){
    if (pendingClose){
      var wasActive = pendingClose.id === activeId;
      if (!wasActive) openFile(pendingClose);
      saveCurrent();
      setTimeout(function(){ closeFile(pendingClose, true); }, 50);
    }
    el.modalOverlay.classList.remove('show'); pendingClose = null;
  });
  el.modalOverlay.addEventListener('click', function(e){
    if (e.target === el.modalOverlay){ el.modalOverlay.classList.remove('show'); pendingClose = null; }
  });

  /* ---------- yazı boyutu / kaydırma ---------- */
  var fontSize = 14;
  function applyFontSize(){
    document.documentElement.style.setProperty('--code-font-size', fontSize + 'px');
    el.zoomLabel.textContent = fontSize + 'px';
    cm.refresh();
  }
  document.getElementById('btn-zoom-in').addEventListener('click', function(){ fontSize = Math.min(22, fontSize + 1); applyFontSize(); });
  document.getElementById('btn-zoom-out').addEventListener('click', function(){ fontSize = Math.max(11, fontSize - 1); applyFontSize(); });

  var wrapOn = false;
  el.wrapBtn.addEventListener('click', function(){
    wrapOn = !wrapOn;
    cm.setOption('lineWrapping', wrapOn);
    el.wrapBtn.classList.toggle('active', wrapOn);
  });

  /* ---------- düğmeler ---------- */
  document.getElementById('btn-new').addEventListener('click', newFile);
  document.getElementById('empty-new').addEventListener('click', newFile);
  document.addEventListener('keydown', function(e){
    if (e.ctrlKey && e.key.toLowerCase() === 'n'){ e.preventDefault(); newFile(); }
  });
  document.getElementById('btn-open').addEventListener('click', openViaPicker);
  document.getElementById('empty-open').addEventListener('click', openViaPicker);
  document.getElementById('btn-save').addEventListener('click', saveCurrent);
  document.getElementById('btn-download').addEventListener('click', downloadCurrent);
  document.getElementById('btn-find').addEventListener('click', function(){ cm.execCommand('findPersistent'); cm.focus(); });

  /* tarayıcının kendi Ctrl+S'ini engelle */
  window.addEventListener('keydown', function(e){
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 's'){ e.preventDefault(); saveCurrent(); }
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'o'){ e.preventDefault(); openViaPicker(); }
  });

  window.addEventListener('beforeunload', function(e){
    if (files.some(function(f){ return f.dirty; })){
      e.preventDefault(); e.returnValue = '';
    }
  });

  /* ---------- başlangıç ---------- */
  renderTabs();
  refreshVisibility();
  updateStatus();
  applyFontSize();
})();
</script>
</body>
</html>
