  function smartEnter(instance){
    if (instance.somethingSelected()){ instance.execCommand('newlineAndIndent'); return; }
    var cur = instance.getCursor();
    var line = instance.getLine(cur.line);
    var before = line.charAt(cur.ch - 1);
    var after = line.charAt(cur.ch);
    var pairs = { '{': '}', '(': ')', '[': ']' };
    if (pairs[before] && after === pairs[before]){
      var outerIndent = (line.match(/^\s*/) || [''])[0];
      var innerIndent = outerIndent + new Array(instance.getOption('indentUnit') + 1).join(' ');
      instance.replaceSelection('\n' + innerIndent + '\n' + outerIndent);
      instance.setCursor({ line: cur.line + 1, ch: innerIndent.length });
      return;
    }
    instance.execCommand('newlineAndIndent');
  }

  /* Shift+Enter: satır "...)" ile bitiyorsa (fonksiyon imzası, if/for/while/foreach/switch
     gibi kontrol ifadeleri) VS2019'daki gibi altına otomatik süslü parantez bloğu açar:
       public void Test()
       {
           |
       }
     İmleç blok içindeki boş satırda (girintili) bırakılır. */
  function smartShiftEnter(instance){
    if (instance.somethingSelected()){ instance.execCommand('newlineAndIndent'); return; }
    var cur = instance.getCursor();
    var line = instance.getLine(cur.line);
    var before = line.slice(0, cur.ch);
    var after = line.slice(cur.ch);
    if (/\)\s*$/.test(before) && after.trim() === ''){
      var outerIndent = (line.match(/^\s*/) || [''])[0];
      var innerIndent = outerIndent + new Array(instance.getOption('indentUnit') + 1).join(' ');
      instance.replaceRange(
        '\n' + outerIndent + '{\n' + innerIndent + '\n' + outerIndent + '}',
        cur
      );
      instance.setCursor({ line: cur.line + 2, ch: innerIndent.length });
      return;
    }
    smartEnter(instance);
  }
