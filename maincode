    refreshVisibility();
    setTimeout(function(){ cm.focus(); cm.refresh(); }, 0);
  }

  function closeFile(file, force){
    if (file.dirty && !force){
      askCloseConfirm(file);
      return;
    }
    var idx = files.indexOf(file);
    files.splice(idx, 1);
    if (activeId === file.id){
      var next = files[idx] || files[idx - 1];
      if (next) openFile(next);
      else { activeId = null; cm.swapDoc(CodeMirror.Doc('', 'text/plain')); refreshVisibility(); }
    }
    renderTabs();
    updateStatus();
  }

