  /* ---------- şablonlar (GitHub reposundaki tek dosyadan) ----------
     Sablonlar dosyası şu formatta olmalı:

     #UNITY-Unity Standard Script(cs)
     {
     using UnityEngine;
     public class [Name] : MonoBehaviour
     {
         void Start()
         {

         }
     }
     }

     "#" sonrası ilk kelime TAG (sadece uzantı eşleşmesi için dahili kullanılır,
     ekranda gösterilmez). "-" sonrası İSİM(UZANTI) — parantez içindeki kısım
     dosya uzantısını repodan belirler (örn "(cs)"), İSİM ise şablon seçilirken
     görünecek etikettir. { ile } arasındaki her şey (kod kendi süslü parantezleri
     dahil) şablonun içeriğidir; kapanış otomatik olarak parantez dengesine göre
     bulunur. İçerikte geçen [Name], şablon uygulanırken dosya adından türetilen
     sınıf adıyla değiştirilir. */
  var SABLONLAR_URL = 'https://raw.githubusercontent.com/vonlabstudio-boop/SphinxCodes/refs/heads/main/Sablonlar';

  // Geriye dönük uyumluluk: İSİM(UZANTI) formatı kullanılmazsa (parantez yoksa)
  // uzantı TAG'dan tahmin edilir.
  var TAG_EXT_MAP = {
    'UNITY':'cs', 'C#':'cs', 'CS':'cs', 'CSHARP':'cs',
    'JS':'js', 'JAVASCRIPT':'js', 'TS':'ts', 'TYPESCRIPT':'ts',
    'PYTHON':'py', 'PY':'py',
    'HTML':'html', 'CSS':'css',
    'JAVA':'java', 'PHP':'php',
    'CPP':'cpp', 'C++':'cpp', 'C':'c',
    'SQL':'sql', 'SHELL':'sh', 'BASH':'sh',
    'JSON':'json', 'MARKDOWN':'md', 'MD':'md',
    'YAML':'yaml', 'XML':'xml'
  };

  var templatesCache = null;

  // Dosya adından ([Name] yerine geçecek) geçerli bir sınıf/tip adı türetir.
  function classNameFromFile(name){
    var base = name.replace(/\.[^.]+$/, '');
    base = base.replace(/[^A-Za-z0-9_]/g, '');
    if (!base || /^[0-9]/.test(base)) base = 'NewBehaviour' + base;
    return base || 'NewBehaviour';
  }

  function parseTemplatesText(text){
    var items = [];
    var headerRe = /^#([^\r\n\-]+)-(.+)$/gm;
    var match;
    while ((match = headerRe.exec(text))){
      var tag = match[1].trim();
      var rawName = match[2].trim();

      // İSİM(UZANTI) formatını çöz: uzantı artık repodan (parantez içinden) geliyor.
      // Örnek: "Unity Standard Script(cs)" -> isim="Unity Standard Script", uzantı="cs"
      var name = rawName, ext = null;
      var extMatch = rawName.match(/^(.*)\(([A-Za-z0-9+#]+)\)\s*$/);
      if (extMatch){
        name = extMatch[1].trim();
        ext = extMatch[2].trim().toLowerCase();
      } else {
        // parantez yoksa geriye dönük uyumluluk için TAG'dan tahmin et
        ext = TAG_EXT_MAP[tag.toUpperCase()] || tag.toLowerCase();
      }

      var openIdx = text.indexOf('{', headerRe.lastIndex);
      if (openIdx === -1) continue;

      var depth = 0, closeIdx = -1;
      for (var i = openIdx; i < text.length; i++){
        var ch = text[i];
        if (ch === '{') depth++;
        else if (ch === '}'){
          depth--;
          if (depth === 0){ closeIdx = i; break; }
        }
      }
      if (closeIdx === -1) continue;

      var body = text.slice(openIdx + 1, closeIdx);
      body = body.replace(/^\r?\n/, '').replace(/\r?\n[ \t]*$/, '');
      items.push({ tag: tag, label: name, ext: ext, content: body });

      headerRe.lastIndex = closeIdx + 1;
    }
    return items;
  }

  function fetchTemplatesIndex(){
    if (templatesCache) return Promise.resolve(templatesCache);
    var bust = (SABLONLAR_URL.indexOf('?') === -1 ? '?' : '&') + 't=' + Date.now();
    return fetch(SABLONLAR_URL + bust, { cache: 'no-store' })
      .then(function(res){
        if (!res.ok) throw new Error('Şablonlar alınamadı (' + res.status + ').');
        return res.text();
      })
      .then(function(text){
        var list = parseTemplatesText(text);
        templatesCache = list;
        return list;
      });
  }

  function openTemplatePicker(){
    var file = files.find(function(f){ return f.id === activeId; });
    if (!file) return;
    selectedTemplate = null;
    templateEl.apply.disabled = true;
    templateEl.previewEmpty.style.display = 'flex';
    templateEl.previewCode.style.display = 'none';
    templateEl.previewCode.textContent = '';
    templateEl.overlay.classList.add('show');
    templateEl.list.innerHTML = '<div class="template-loading">Şablonlar yükleniyor…</div>';
    fetchTemplatesIndex().then(function(list){
      renderTemplateList(list, file.ext);
    }).catch(function(err){
      templateEl.list.innerHTML = '<div class="template-error">' + err.message + '</div>';
    });
  }

  // TAG sadece uzantı eşleşmesini bulmak için kullanılır; ekranda görünmez,
  // sadece şablonun İSMİ (tag'dan sonraki kısım) gösterilir.
  function renderTemplateList(list, currentExt){
    if (!list || !list.length){
      templateEl.list.innerHTML = '<div class="template-error">Repoda henüz şablon yok.</div>';
      return;
    }
    // uzantısı mevcut dosyayla eşleşenler en üstte, yıldızlı; tag/grup başlığı yok, düz liste
    var featured = list.filter(function(t){ return t.ext === currentExt; });
    var rest = list.filter(function(t){ return t.ext !== currentExt; });
    var ordered = featured.concat(rest);

    var html = '';
    ordered.forEach(function(t){
      var idx = list.indexOf(t);
      var isFeatured = t.ext === currentExt;
      html += '<div class="template-item' + (isFeatured ? ' featured' : '') + '" data-idx="' + idx + '">' +
        (isFeatured ? '<span class="star">★</span>' : '') +
        '<span>' + t.label + '</span>' +
        '</div>';
    });
    templateEl.list.innerHTML = html;

    Array.prototype.slice.call(templateEl.list.querySelectorAll('.template-item')).forEach(function(item){
      item.addEventListener('click', function(){
        var idx = parseInt(item.getAttribute('data-idx'), 10);
        selectTemplate(templatesCache[idx], item);
      });
    });
  }

  function selectTemplate(template, itemEl){
    selectedTemplate = template;
    Array.prototype.slice.call(templateEl.list.querySelectorAll('.template-item')).forEach(function(node){
      node.classList.toggle('active', node === itemEl);
    });
    var file = files.find(function(f){ return f.id === activeId; });
    var className = file ? classNameFromFile(file.name) : '[Name]';
    var preview = template.content.split('[Name]').join(className);
    templateEl.previewEmpty.style.display = 'none';
    templateEl.previewCode.style.display = 'block';
    templateEl.previewCode.textContent = preview;
    templateEl.apply.disabled = false;
  }

  function applySelectedTemplate(){
    if (!selectedTemplate) return;
    var file = files.find(function(f){ return f.id === activeId; });
    if (!file) return;
    if (cm.getValue().trim() !== ''){
      var ok = window.confirm('Mevcut içerik silinip şablonla değiştirilecek. Devam edilsin mi?');
      if (!ok) return;
