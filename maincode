    while ((m = re.exec(text))){ if (!seen[m[0]]){ seen[m[0]] = true; bufferWords.push(m[0]); } }

    var lowerWord = word.toLowerCase();
    var listSeen = {};
    var list = [];
    langWords.concat(bufferWords).forEach(function(w){
      var lw = w.toLowerCase();
      if (listSeen[lw] || lw === lowerWord) return;
      if (lw.indexOf(lowerWord) !== 0) return;
      listSeen[lw] = true;
      list.push(w);
    });
    if (!list.length) return null;
    list.sort(function(a, b){ return a.length - b.length || a.localeCompare(b); });
    return { list: list.slice(0, 30), from: CodeMirror.Pos(cur.line, start), to: CodeMirror.Pos(cur.line, cur.ch) };
  }

