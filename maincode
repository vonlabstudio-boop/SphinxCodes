<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sphinx Scripts</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,450;9..144,560&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/dialog/dialog.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/fold/foldgutter.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/hint/show-hint.min.css">

<style>
:root{
  --bg:            #1e1e1e;
  --panel:         #252526;
  --panel-2:       #2d2d30;
  --editor-bg:     #1e1e1e;
  --border:        #3c3c3c;
  --border-soft:   #2d2d30;

  --text:          #d4d4d4;
  --text-dim:      #9d9d9d;
  --text-faint:    #6a6a6a;

  --accent:        #569cd6;
  --accent-soft:   rgba(86,156,214,.16);
  --accent-dim:    rgba(86,156,214,.55);
  --sage:          #4ec9b0;
  --sage-soft:     rgba(78,201,176,.14);
  --danger:        #f14c4c;
  --danger-soft:   rgba(241,76,76,.14);

  --radius:        7px;
  --radius-sm:     5px;
  --ease:          cubic-bezier(.4,0,.2,1);

  --code-font-size: 14px;

  --font-display: 'Fraunces', serif;
  --font-ui:      'Manrope', -apple-system, sans-serif;
  --font-mono:    'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
}

@media (prefers-reduced-motion: reduce){
  *{ animation-duration: .001ms !important; transition-duration: .001ms !important; }
}

*{ box-sizing: border-box; }
html,body{ height:100%; margin:0; }
body{
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-ui);
  overflow:hidden;
  -webkit-font-smoothing: antialiased;
}
button{ font-family: inherit; }
::selection{ background: var(--accent-soft); }

/* subtle scrollbars everywhere */
*{ scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
*::-webkit-scrollbar{ width:9px; height:9px; }
*::-webkit-scrollbar-thumb{ background: var(--border); border-radius: 10px; border:2px solid var(--bg); }
*::-webkit-scrollbar-track{ background: transparent; }

:focus-visible{ outline: 2px solid var(--accent-dim); outline-offset: 2px; border-radius: 4px; }

/* ============================================================
   Layout iskeleti
   ============================================================ */
.app{
  height: 100vh;
  display: flex;
  flex-direction: column;
  animation: app-in .5s var(--ease);
}
@keyframes app-in{ from{ opacity:0; transform: translateY(4px); } to{ opacity:1; transform:none; } }

/* ---------- header ---------- */
header{
  height: 54px;
  flex: 0 0 auto;
  display:flex;
  align-items:center;
  gap:18px;
  padding: 0 16px;
  background: var(--panel);
  border-bottom: 1px solid var(--border);
}

.wordmark{
  display:flex;
  align-items:baseline;
  gap:2px;
  font-family: var(--font-display);
  font-weight: 560;
  font-size: 20px;
  letter-spacing: .2px;
  color: var(--text);
  user-select:none;
  flex: 0 0 auto;
}
.wordmark .cursor{
  display:inline-block;
  width:8px; height:17px;
  background: var(--accent);
  margin-left:3px;
  border-radius:1px;
  animation: blink 1.1s steps(1) infinite;
  transform: translateY(2px);
}
@keyframes blink{ 0%,45%{ opacity:1; } 46%,95%{ opacity:0; } 96%,100%{ opacity:1; } }

.toolbar{
  display:flex;
  align-items:center;
  gap:4px;
  flex: 1 1 auto;
}
.divider{
  width:1px; height:22px;
  background: var(--border);
  margin: 0 6px;
  flex: 0 0 auto;
}

.icon-btn{
  display:flex; align-items:center; justify-content:center;
  gap:7px;
  width:36px; height:36px;
  border-radius: var(--radius-sm);
  background: transparent;
  border: 1px solid transparent;
  color: var(--text-dim);
  cursor:pointer;
  transition: background .15s var(--ease), color .15s var(--ease), border-color .15s var(--ease);
}
.icon-btn.wide{ width:auto; padding:0 12px; font-size:13px; font-weight:600; color: var(--text); }
.icon-btn svg{ width:17px; height:17px; flex:0 0 auto; }
.icon-btn:hover{ background: var(--panel-2); color: var(--text); }
.icon-btn:active{ transform: scale(.94); }
.icon-btn.active{ background: var(--accent-soft); color: var(--accent); border-color: rgba(217,154,78,.3); }
.icon-btn[disabled]{ opacity:.35; pointer-events:none; }
.icon-btn.primary{ background: var(--accent-soft); color: var(--accent); border-color: rgba(217,154,78,.3); }
.icon-btn.primary:hover{ background: rgba(217,154,78,.22); }

.zoom-group{
  display:flex; align-items:center; gap:2px;
  border:1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 2px;
  margin-left:auto;
  flex: 0 0 auto;
}
.zoom-group .icon-btn{ width:28px; height:28px; }
.zoom-group span{ font-size:11.5px; color: var(--text-dim); width:38px; text-align:center; font-variant-numeric: tabular-nums; }

.ac-badge{
  display:flex; align-items:center; gap:6px;
  padding: 5px 11px;
  border-radius: 20px;
  border: 1px solid rgba(127,174,146,.35);
  background: var(--sage-soft);
  color: var(--sage);
  font-size: 11.5px;
  font-weight: 600;
  flex: 0 0 auto;
  margin-left: 10px;
  white-space: nowrap;
  transition: opacity .15s var(--ease), transform .15s var(--ease);
}
.ac-badge.hidden{ opacity:0; pointer-events:none; transform: translateX(4px); position:absolute; }
.ac-badge .ac-dot{ width:6px; height:6px; border-radius:50%; background: var(--sage); flex:0 0 auto; }

/* ---------- tab bar ---------- */
.tabbar{
  display:flex;
  align-items:stretch;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  overflow-x:auto;
  flex: 0 0 auto;
  min-height: 40px;
}
.tabbar.empty{ display:none; }

.tab{
  display:flex; align-items:center; gap:8px;
  padding: 0 10px 0 14px;
  height:40px;
  min-width: 120px;
  max-width: 220px;
  border-right: 1px solid var(--border-soft);
  color: var(--text-dim);
  font-size: 13px;
  cursor: pointer;
  position: relative;
  user-select:none;
  white-space:nowrap;
  transition: background .12s var(--ease), color .12s var(--ease);
}
.tab:hover{ background: var(--panel); color: var(--text); }
.tab.active{ background: var(--editor-bg); color: var(--text); }
.tab.active::after{
  content:'';
  position:absolute; left:0; right:0; bottom:-1px; height:2px;
  background: var(--accent);
}
.tab .name{ overflow:hidden; text-overflow:ellipsis; flex:1 1 auto; font-family: var(--font-mono); font-size:12.5px; }
.tab .dot{
  width:6px; height:6px; border-radius:50%;
  background: var(--accent);
  flex:0 0 auto;
  animation: pulse 1.8s ease-in-out infinite;
}
@keyframes pulse{ 0%,100%{ opacity:.5; } 50%{ opacity:1; } }
.tab .close{
  width:18px; height:18px; border-radius:4px;
  display:flex; align-items:center; justify-content:center;
  flex:0 0 auto; color: var(--text-faint);
  opacity:0;
  transition: opacity .12s, background .12s, color .12s;
}
.tab:hover .close, .tab.active .close{ opacity:1; }
.tab .close:hover{ background: var(--danger-soft); color: var(--danger); }
.tab .close svg{ width:11px; height:11px; }
.tab.dirty .close{ opacity:0; }
.tab.dirty:hover .close{ opacity:1; }
.tab.dirty:hover .dot{ display:none; }

/* ---------- editor area ---------- */
main{ flex:1 1 auto; min-height:0; position:relative; }
.editor-wrap{ position:absolute; inset:0; }
.CodeMirror{
  height:100%;
  background: var(--editor-bg) !important;
  color: var(--text) !important;
  font-family: var(--font-mono) !important;
  font-size: var(--code-font-size);
  line-height: 1.65;
  padding: 4px 0;
}
.CodeMirror-gutters{ background: var(--editor-bg) !important; border-right: 1px solid var(--border-soft) !important; }
.CodeMirror-linenumber{ color: var(--text-faint) !important; padding: 0 14px 0 18px !important; }
.CodeMirror-cursor{ border-left: 2px solid var(--accent) !important; }
.CodeMirror-activeline-background{ background: rgba(255,255,255,.025) !important; }
.CodeMirror-matchingbracket{ color: var(--accent) !important; background: var(--accent-soft); border-radius:3px; }
.CodeMirror-selected{ background: var(--accent-soft) !important; }
.CodeMirror-foldgutter{ width: 12px; }
.CodeMirror-foldgutter-open, .CodeMirror-foldgutter-folded{ color: var(--text-faint); cursor:pointer; }
.CodeMirror-foldmarker{ color: var(--accent); }
.cm-trailingspace{ background: var(--danger-soft); }

/* syntax palette — Visual Studio 2019 (Dark) referans alınmıştır */
.cm-keyword{ color: #569cd6 !important; }              /* public, class, if, return… */
.cm-atom{ color: #569cd6 !important; }                 /* true/false/null */
.cm-number{ color: #b5cea8 !important; }
.cm-def{ color: #dcdcaa !important; }                  /* metot/fonksiyon adları (Update, GetComponent…) */
.cm-variable{ color: #9cdcfe !important; }             /* yerel değişken/parametre — artık düz beyaz değil */
.cm-variable-2{ color: #9cdcfe !important; }            /* parametreler */
.cm-variable-3, .cm-type{ color: #4ec9b0 !important; }  /* sınıf/tip adları — MonoBehaviour, GameObject… (yeşilimsi/teal) */
.cm-property{ color: #9cdcfe !important; }
.cm-operator{ color: #d4d4d4 !important; }             /* operatörler VS'de de nötr beyaz kalır */
.cm-comment{ color: #6a9955 !important; font-style: italic; }
.cm-string, .cm-string-2{ color: #ce9178 !important; }
.cm-meta{ color: #9b9b9b !important; }                 /* using / #region gibi ön işlemci ifadeleri */
.cm-qualifier{ color: #d7ba7d !important; }
.cm-builtin{ color: #569cd6 !important; }               /* string, int, bool, void gibi ilkel tipler — VS'de keyword mavisi */
.cm-bracket{ color: #d4d4d4 !important; }
.cm-tag{ color: #569cd6 !important; }
.cm-attribute{ color: #9cdcfe !important; }
.cm-header{ color: var(--accent) !important; font-weight:600; }
.cm-link{ color: #569cd6 !important; text-decoration: underline; }
.cm-error{ color: var(--danger) !important; }

/* Unity/C# özel katman: bilinen sınıf/tip adları her zaman teal (VS'deki "Type" rengi) */
.cm-unity-type{ color: #4ec9b0 !important; }
/* Unity yaşam döngüsü ve API metotları: VS'deki metot sarısı */
.cm-unity-method{ color: #dcdcaa !important; }

/* otomatik tamamlama kutusu */
.CodeMirror-hints{
  background: var(--panel) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--radius-sm) !important;
  box-shadow: 0 14px 32px rgba(0,0,0,.5) !important;
  font-family: var(--font-mono) !important;
  font-size: 13px !important;
  padding: 4px !important;
  z-index: 30;
}
.CodeMirror-hint{
  color: var(--text) !important;
  padding: 6px 10px !important;
  border-radius: 4px !important;
  white-space: nowrap;
}
li.CodeMirror-hint-active{
  background: var(--accent-soft) !important;
  color: var(--accent) !important;
}

/* find / dialog */
.CodeMirror-dialog{
  background: var(--panel) !important;
  color: var(--text) !important;
  border-bottom: 1px solid var(--border) !important;
  font-family: var(--font-ui) !important;
  padding: 8px 12px !important;
}
.CodeMirror-dialog input{
  background: var(--panel-2) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
  border-radius: 4px;
  padding: 4px 8px;
  font-family: var(--font-mono) !important;
}
.CodeMirror-search-hint{ color: var(--text-dim); }

/* ---------- empty state ---------- */
.empty-state{
  position:absolute; inset:0;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:18px;
  text-align:center;
  color: var(--text-dim);
  padding: 20px;
}
.empty-state.hidden{ display:none; }
.empty-state svg{ width:46px; height:46px; color: var(--text-faint); }
.empty-state h1{
  font-family: var(--font-display);
  font-weight: 450;
  font-size: 22px;
  color: var(--text);
  margin: 0;
}
.empty-state p{ margin:0; font-size:13.5px; max-width: 340px; line-height:1.6; color:var(--text-dim); }
.empty-actions{ display:flex; gap:10px; margin-top:6px; }
.pill-btn{
  display:flex; align-items:center; gap:8px;
  padding: 9px 16px;
  border-radius: 20px;
  border:1px solid var(--border);
  background: var(--panel);
  color: var(--text);
  font-size: 13px; font-weight:600;
  cursor:pointer;
  transition: border-color .15s, background .15s, transform .1s;
}
.pill-btn:hover{ border-color: var(--accent-dim); background: var(--accent-soft); color: var(--accent); }
.pill-btn:active{ transform: scale(.97); }
.pill-btn svg{ width:15px; height:15px; }

.dropzone-active .editor-wrap::after,
.dropzone-active .empty-state::after{
  content:'';
  position:absolute; inset:8px;
  border: 1.5px dashed var(--accent);
  border-radius: 10px;
  background: var(--accent-soft);
  pointer-events:none;
}
.dropzone-active .editor-wrap{ position:absolute; }

/* ---------- status bar ---------- */
.statusbar{
  flex: 0 0 auto;
  height: 28px;
  display:flex; align-items:center;
  gap:16px;
  padding: 0 14px;
  background: var(--panel);
  border-top: 1px solid var(--border);
  font-size: 11.5px;
  color: var(--text-dim);
  font-family: var(--font-mono);
  user-select:none;
}
.statusbar .seg{ display:flex; align-items:center; gap:6px; }
.statusbar .save-dot{ width:6px; height:6px; border-radius:50%; background: var(--sage); flex:0 0 auto; }
.statusbar .save-dot.dirty{ background: var(--accent); animation: pulse 1.8s ease-in-out infinite; }
.statusbar .grow{ flex:1 1 auto; }
.statusbar .flash{ color: var(--sage); opacity:0; transition: opacity .2s; }
.statusbar .flash.show{ opacity:1; }

/* ---------- modal ---------- */
.modal-overlay{
  position:fixed; inset:0;
  background: rgba(10,12,15,.55);
  display:flex; align-items:center; justify-content:center;
  z-index: 50;
  opacity:0; pointer-events:none;
  transition: opacity .15s var(--ease);
}
.modal-overlay.show{ opacity:1; pointer-events:auto; }
.modal{
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 22px;
  width: 320px;
  transform: translateY(6px) scale(.98);
  transition: transform .15s var(--ease);
  box-shadow: 0 20px 50px rgba(0,0,0,.45);
}
.modal-overlay.show .modal{ transform:none; }
.modal h2{ font-family: var(--font-display); font-weight:560; font-size:17px; margin:0 0 8px; }
.modal p{ font-size: 13px; color: var(--text-dim); line-height:1.55; margin:0 0 18px; }
.modal .row{ display:flex; gap:8px; justify-content:flex-end; }
.modal button{
  padding: 8px 14px; border-radius: var(--radius-sm); font-size:12.5px; font-weight:600;
  border:1px solid var(--border); background: var(--panel-2); color: var(--text); cursor:pointer;
  transition: background .15s, border-color .15s;
}
.modal button:hover{ background: var(--border); }
.modal button.danger{ background: var(--danger-soft); border-color: rgba(194,107,95,.35); color: var(--danger); }
.modal button.danger:hover{ background: rgba(194,107,95,.28); }
.modal button.primary{ background: var(--accent-soft); border-color: rgba(217,154,78,.35); color: var(--accent); }
.modal button.primary:hover{ background: rgba(217,154,78,.28); }
.modal button[disabled]{ opacity:.4; cursor:not-allowed; pointer-events:none; }
.name-field{
  width:100%;
  background: var(--panel-2);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 13.5px;
  padding: 9px 11px;
  border-radius: var(--radius-sm);
  margin-bottom: 6px;
}
.name-field:focus{ border-color: var(--accent-dim); }
.name-field.invalid{ border-color: var(--danger); }
.field-error{
  min-height: 16px;
  font-size: 12px;
  color: var(--danger);
  margin-bottom: 12px;
}

.template-modal{ width:640px; max-width:92vw; max-height:80vh; display:flex; flex-direction:column; }
.template-body{
  display:flex; gap:14px;
  height:360px; margin-bottom:14px;
}
.template-list{
  flex:0 0 190px;
  overflow-y:auto;
  display:flex; flex-direction:column; gap:6px;
  padding-right:4px;
  border-right:1px solid var(--border-soft);
}
.template-item{
  display:flex; align-items:center; gap:7px;
  padding:9px 10px; border-radius: var(--radius-sm);
  border:1px solid var(--border); background: var(--panel-2);
  cursor:pointer; font-size:12.5px; color:var(--text);
  transition: background .12s var(--ease), border-color .12s var(--ease);
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.template-item:hover{ background: var(--border); }
.template-item.featured{ border-color: rgba(217,154,78,.45); }
.template-item.active{
  border-color: var(--accent-dim);
  background: var(--accent-soft);
  color: var(--accent);
}
.template-item .star{ color:#d99a4e; flex:0 0 auto; font-size:11px; }
.template-preview{
  flex:1 1 auto; min-width:0;
  background: var(--editor-bg);
  border:1px solid var(--border-soft);
  border-radius: var(--radius-sm);
  overflow:auto;
  position:relative;
}
.template-preview-empty{
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
  text-align:center; padding:20px;
  font-size:12.5px; color: var(--text-faint);
}
.template-preview-code{
  margin:0; padding:12px 14px;
  font-family: var(--font-mono); font-size:12.5px; line-height:1.6;
  color: var(--text); white-space:pre; tab-size:4;
}
.template-loading, .template-error{ font-size:13px; color: var(--text-dim); padding:6px 2px; }
.template-error{ color: var(--danger); }

/* dosya açık değilken sadece "yeni dosya" ve "dosya aç" görünsün */
.file-tool.ft-hidden{ display:none !important; }

@media (max-width: 640px){
  header{ gap:10px; padding:0 10px; }
  .wordmark span.label{ display:none; }
  .zoom-group{ display:none; }
  .tab{ min-width: 96px; }
  .template-modal{ width: 88vw; }
  .template-body{ flex-direction:column; height:auto; max-height:60vh; }
  .template-list{ flex:0 0 auto; max-height:150px; border-right:none; border-bottom:1px solid var(--border-soft); padding-right:0; padding-bottom:8px; }
  .template-preview{ min-height:160px; }
}
</style>
</head>
<body>

<div class="app" id="app">

  <header>
    <div class="wordmark">Sphinx<span class="cursor"></span></div>

    <div class="toolbar">
      <button class="icon-btn" id="btn-new" title="Yeni dosya (Ctrl+N)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
      </button>
      <button class="icon-btn" id="btn-open" title="Dosya aç (Ctrl+O)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
      </button>

      <div class="divider file-tool" id="divider-a"></div>

      <button class="icon-btn file-tool" id="btn-save" title="Kaydet (Ctrl+S)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h11l3 3v13a1 1 0 01-1 1H5a1 1 0 01-1-1V5a1 1 0 011-1z"/><path d="M8 4v5h7V4M8 20v-6h8v6"/></svg>
      </button>
      <button class="icon-btn file-tool" id="btn-download" title="İndir">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v11m0 0l-4-4m4 4l4-4M5 19h14"/></svg>
      </button>

      <div class="divider file-tool" id="divider-b"></div>

      <button class="icon-btn file-tool" id="btn-find" title="Bul / Değiştir (Ctrl+F)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      </button>
      <button class="icon-btn file-tool" id="btn-wrap" title="Satır kaydırma">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h12a3 3 0 010 6h-2m0 0l2-2m-2 2l2 2M4 18h4"/></svg>
