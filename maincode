    var cur = cm.getCursor();
    var sel = cm.getSelection();
    el.modeLabel.textContent = file.modeLabel;
    el.posLabel.textContent = 'Satır ' + (cur.line + 1) + ', Sütun ' + (cur.ch + 1) + (sel ? '  ·  ' + sel.length + ' seçili' : '');
    el.lenLabel.textContent = cm.getValue().length + ' karakter';
