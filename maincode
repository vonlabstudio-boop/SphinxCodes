  /* ---------- dosya işlemleri ---------- */
  function createFile(name, content, handle){
    var m = modeFor(name);
    var ext = (name.split('.').pop() || '').toLowerCase();
    var doc = CodeMirror.Doc(content || '', m.mime);
    var file = {
      id: nextId(), name: name, doc: doc, ext: ext,
      modeLabel: m.label, dirty: false, handle: handle || null
    };
    doc.on('change', function(){
      if (activeId === file.id){ file.dirty = true; renderTabs(); updateStatus(); }
      else { file.dirty = true; }
    });
    files.push(file);
    return file;
  }

  function openFile(file){
    activeId = file.id;
